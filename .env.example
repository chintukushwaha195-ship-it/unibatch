# ==============================================
# UNIBATCH — Transparent Trading Fund
# Phase 1 environment configuration
# ==============================================
#
# Copy this file to `.env.local` (local dev) or set these as environment
# variables in your Vercel project settings.
# NEVER commit real secrets to version control.

# ---------- Database ----------
# MongoDB connection string — use MongoDB Atlas for production.
# https://www.mongodb.com/atlas
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name inside MongoDB.
DB_NAME=unibatch

# ---------- Admin credentials (Phase 1) ----------
# Username for the admin login page.
ADMIN_USERNAME=admin001

# bcrypt hash of your admin password (cost factor 12 recommended).
# Generate with Node.js:
#   node -e "const b=require('bcryptjs'); b.hash('your-password-here',12).then(console.log)"
# Or with npx:
#   npx -y node -e "const b=require('bcryptjs'); b.hash('your-password',12).then(console.log)"
# Paste the resulting $2b$12$... string here.
# DO NOT paste your plaintext password — only the hash.
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_THIS_WITH_YOUR_ACTUAL_BCRYPT_HASH

# ---------- SMTP (Outlook / Office 365) ----------
# SMTP_HOST and SMTP_PORT are hardcoded to Outlook values (smtp.office365.com:587).
# Only the credentials and recipient are configurable.

# Your Outlook / Microsoft 365 email address (used as SMTP sender).
SMTP_USER=you@outlook.com

# Your Outlook / Microsoft 365 account password or app password.
# If your account has MFA enabled, generate an App Password at:
# https://account.microsoft.com/security → Advanced security → App passwords
SMTP_PASSWORD=your-outlook-password-or-app-password

# ---------- Recovery & OTP destination ----------
# Email address where OTP codes and recovery notices are sent.
# This should be an address you have exclusive access to.
RECOVERY_EMAIL=you@outlook.com

# ---------- Session signing ----------
# Secret used to HMAC-sign session IDs stored in HttpOnly cookies.
# Generate with: openssl rand -hex 48
# Must be at least 48 characters. Keep this secret — rotate if compromised.
SESSION_SECRET=replace-with-a-long-random-string-at-least-96-chars

# ---------- JWT (kept for internal use) ----------
# Used internally. Generate with: openssl rand -hex 48
JWT_SECRET=replace-with-another-long-random-string-at-least-64-chars

# ---------- CORS ----------
# Comma-separated allowed origins or "*" for all public API routes.
# The admin login cookie routes are same-origin and are unaffected by this setting.
CORS_ORIGINS=*

# ---------- Optional: BscScan / RPC ----------
# Not required. On-chain sync uses public BSC JSON-RPC endpoints.
# Set to a paid RPC URL (Alchemy, QuickNode) to extend BSC_RPC_URLS in route.js.
BSCSCAN_API_KEY=

# ==============================================
# DEPRECATED (v1.0 → v1.1)
# ==============================================
# These variables are no longer used in Phase 1+.
# They are kept here for reference only — remove them from your environment.
#
# ADMIN_USER       → replaced by ADMIN_USERNAME
# ADMIN_PASS       → replaced by ADMIN_PASSWORD_HASH (bcrypt hash)

# ==============================================
# UNIBATCH — Transparent Trading Fund
# Phase 2 environment configuration
# ==============================================
#
# Copy this file to .env.local for local development, or set these as
# environment variables in your Vercel project settings for production.
#
# NEVER commit real secrets to version control.
# Every variable marked (required) must be set — the app will log a
# clear error and return 503 / 401 if required variables are missing.

# ---------- Database (required) ----------
# MongoDB connection string. Use MongoDB Atlas for production.
# https://www.mongodb.com/atlas
#
# Whitelist 0.0.0.0/0 in Atlas Network Access when deploying to Vercel,
# or add Vercel's outbound CIDR ranges.
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# The MongoDB database name. Defaults to "unibatch" if not set.
DB_NAME=your_database_name

# ---------- Admin credentials (required) ----------
# Username shown on the admin login page.
ADMIN_USERNAME=YOUR_ADMIN_USERNAME

# bcrypt hash of your admin password (cost factor 12 recommended).
#
# Generate with Node.js (run this once, then paste the output below):
#   node -e "const b=require('bcryptjs'); b.hash('YOUR-PASSWORD-HERE', 12).then(console.log)"
#
# The output looks like:  $2b$12$...72 more characters...
# Paste the FULL hash — do NOT paste your plaintext password.
# The app will refuse to log anyone in if this is empty or not a valid bcrypt hash.
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_THIS_WITH_YOUR_ACTUAL_BCRYPT_HASH

# ---------- SMTP — Outlook / Office 365 (required for OTP + recovery) ----------
# SMTP host and port are hardcoded to Outlook values:
#   smtp.office365.com : 587 (STARTTLS)
# Only credentials and destination are configurable here.

# Your Outlook / Microsoft 365 email address (used as SMTP sender).
SMTP_USER=you@outlook.com

# Your Outlook / Microsoft 365 account password.
# If your account has MFA enabled, generate an App Password:
#   https://account.microsoft.com/security → Advanced security → App passwords
SMTP_PASSWORD=your-outlook-password-or-app-password

# ---------- OTP / recovery destination (required) ----------
# The email address where OTP codes and recovery instructions are sent.
# This should be a mailbox only you can access.
# Typically the same as SMTP_USER, but can be different.
RECOVERY_EMAIL=you@outlook.com

# ---------- Session signing (required) ----------
# HMAC-SHA256 key used to sign session IDs stored in HttpOnly cookies.
# Generate a random value:
#   openssl rand -hex 64
# Must be long (≥ 48 characters) and kept secret.
# Rotate this value to immediately invalidate all active admin sessions.
SESSION_SECRET=replace-with-a-long-random-string-at-least-96-characters-long

# ---------- JWT secret (recommended) ----------
# Used to sign JWTs issued for API consumers / backward compatibility.
# Generate:  openssl rand -hex 48
# Falls back to SESSION_SECRET if not set, but setting it separately is better practice.
JWT_SECRET=replace-with-another-long-random-string-at-least-64-characters

# ---------- CORS (optional) ----------
# Allowed origins for the /api/* routes.
# Use "*" for fully public APIs (default) or a comma-separated list of allowed domains.
# Note: admin cookie routes are same-origin — this setting does not affect them.
CORS_ORIGINS=*

# ---------- BscScan API key (optional) ----------
# Not currently required — on-chain verification uses public BSC JSON-RPC nodes.
# Set a paid RPC URL in lib/blockchain.js if public nodes become unreliable.
BSCSCAN_API_KEY=

# ==============================================
# Deployment checklist
# ==============================================
# 1. Generate ADMIN_PASSWORD_HASH (see instructions above).
# 2. Generate SESSION_SECRET and JWT_SECRET using openssl rand.
# 3. Verify SMTP credentials work by sending a test email from your Outlook account.
# 4. In MongoDB Atlas → Network Access → add 0.0.0.0/0 (or Vercel CIDR).
# 5. Set all variables in Vercel → Project Settings → Environment Variables.
# 6. Deploy. The app logs clear errors to Vercel Functions logs for any missing variable.
#
# ==============================================
# Removed in Phase 2 (do not use)
# ==============================================
# ADMIN_USER   → replaced by ADMIN_USERNAME
# ADMIN_PASS   → replaced by ADMIN_PASSWORD_HASH (bcrypt hash, never plaintext)

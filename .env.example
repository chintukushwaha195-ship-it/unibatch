# ==============================================
# UNIBATCH — Transparent Trading Fund
# Example environment file
# ==============================================
#
# Copy this file to `.env.local` (or `.env` for prod) and fill in the values.
# NEVER commit real secrets to git.

# ---------- Database ----------
# MongoDB connection string. Use MongoDB Atlas for production.
# https://www.mongodb.com/atlas
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name inside MongoDB.
DB_NAME=unibatch

# ---------- Admin authentication ----------
# Credentials used to sign in at /admin-login. Change these before deploying.
ADMIN_USER=admin001
ADMIN_PASS=change-me-to-a-strong-password

# HMAC secret used to sign JWT session tokens.
# Generate one with: openssl rand -hex 48
JWT_SECRET=replace-with-a-long-random-string-at-least-64-chars

# Email displayed in the (currently mocked) password recovery flow.
RECOVERY_EMAIL=you@example.com

# ---------- CORS ----------
# Comma-separated allowed origins or "*" for all. Used for /api/* routes.
CORS_ORIGINS=*

# ---------- Optional: BscScan / RPC ----------
# Not currently required. On-chain sync uses public BSC JSON-RPC endpoints
# (bsc-pokt.nodies.app + 1rpc.io/bnb as fallback). If you have a paid RPC
# (Alchemy, QuickNode, Ankr), you can extend the code in app/api/[[...path]]/route.js
# to prefer it. A BscScan API key is currently unused but kept here for future use.
BSCSCAN_API_KEY=
